{
  "run_name": "transformer_umls_fast",
  "seed": 42,
  "data": {
    "pairs_txt": "embedding_training_v2/data/umls_pairs.txt",
    "umls_mrconso": "META/MRCONSO.RRF",
    "max_pairs": 1000000
  },
  "trainer": {
    "epochs": 2,
    "batch_size": 512,
    "lr": 0.0003,
    "checkpoint_every": 1,
    "resume": false
  },
  "alignment": {
    "base_model_type": "transformer",
    "base_model_dir": "embedding_training_v2/outputs/models/transformer_fast",
    "temperature": 0.07,
    "projection_dim": 256,
    "freeze_base": true,
    "save_projected_inference": true
  },
  "output": {
    "root": "embedding_training_v2/outputs/models/transformer_umls_fast"
  }
}