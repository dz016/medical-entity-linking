{
  "run_name": "transformer_umls_enhanced",
  "seed": 42,
  "data": {
    "pairs_txt": "training/data/umls_pairs.txt",
    "umls_mrconso": "META/MRCONSO.RRF",
    "umls_mrsty": "META/MRSTY.RRF",
    "umls_mrrel": "META/MRREL.RRF",
    "cui_to_type_json": "training/data/cui_to_type_transformer.json",
    "relation_pairs_json": "training/data/relation_pairs_transformer.json"
  },
  "trainer": {
    "epochs": 10,
    "batch_size": 256,
    "lr": 0.0003,
    "checkpoint_every": 1,
    "resume": false
  },
  "alignment": {
    "base_model_type": "transformer",
    "base_model_dir": "models/transformer_fast",
    "temperature": 0.07,
    "projection_dim": 256,
    "freeze_base": false,
    "save_projected_inference": true
  },
  "enhanced": {
    "max_types": 25,
    "type_loss_weight": 0.1,
    "type_loss_warmup": true,
    "relation_sampling_ratio": 0.3,
    "relation_types": [
      "has_manifestation",
      "may_treat",
      "finding_site_of"
    ]
  },
  "output": {
    "root": "models/transformer_umls_enhanced"
  }
}
