{
  "run_name": "word2vec_synonym_type",
  "seed": 42,
  "data": {
    "pairs_txt": "training/data/umls_pairs.txt",
    "umls_mrconso": "META/MRCONSO.RRF",
    "umls_mrsty": "META/MRSTY.RRF",
    "umls_mrrel": "META/MRREL.RRF",
    "cui_to_type_json": "training/data/cui_to_type.json",
    "relation_pairs_json": "training/data/relation_pairs.json"
  },
  "trainer": {
    "epochs": 10,
    "batch_size": 512,
    "lr": 0.0003,
    "checkpoint_every": 1,
    "resume": false
  },
  "alignment": {
    "base_model_type": "word2vec",
    "base_model_dir": "models/word2vec",
    "temperature": 0.07,
    "projection_dim": 256,
    "freeze_base": true,
    "save_projected_inference": true
  },
  "enhanced": {
    "max_types": 25,
    "type_loss_weight": 0.1,
    "type_loss_warmup": true,
    "relation_sampling_ratio": 0.0,
    "relation_types": []
  },
  "output": {
    "root": "models/word2vec_synonym_type"
  }
}
